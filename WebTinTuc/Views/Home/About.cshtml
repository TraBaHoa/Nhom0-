@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="bg-primary text-white p-4">
            <h2 class="fw-bold mb-0"><i class="fas fa-university me-2"></i>GIỚI THIỆU TRƯỜNG THPT NGUYỄN DU</h2>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="text-primary fw-bold border-bottom pb-2">Lịch sử hình thành</h4>
                    <p style="text-align: justify;">
                        Trường THPT Nguyễn Du tự hào là một trong những ngôi trường có bề dày truyền thống dạy và học tại TP. Hồ Chí Minh.
                        Với đội ngũ giáo viên tâm huyết và cơ sở vật chất hiện đại, trường luôn là nơi ươm mầm cho những tài năng trẻ.
                    </p>
                    <h4 class="text-primary fw-bold border-bottom pb-2 mt-4">Tầm nhìn & Sứ mệnh</h4>
                    <ul>
                        <li>Xây dựng môi trường giáo dục hạnh phúc, năng động.</li>
                        <li>Đào tạo những thế hệ học sinh có tri thức, đạo đức và kỹ năng hội nhập.</li>
                        <li>Không ngừng đổi mới phương pháp dạy và học.</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <img src="~/images/banner-chinh.jpg" class="img-fluid rounded shadow-sm mb-3" alt="Trường Nguyễn Du">
                        <div class="alert alert-info border-0">
                            <h6 class="fw-bold"><i class="fas fa-info-circle me-2"></i>Thông tin liên hệ:</h6>
                            <p class="small mb-0">Địa chỉ: XXI Đồng Nai, Phường 15, Quận 10, TP. Hồ Chí Minh</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>