@model WebTinTuc.Models.ViewModels.HomeViewModel

<div class="row">
    @* --- CỘT TRÁI: DANH MỤC --- *@
    <div class="col-md-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-bold">DANH MỤC</div>
            <div class="list-group list-group-flush shadow-sm">
                
                @* 1. TIN TỨC *@
                <a href="#submenuTinTuc" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="true" aria-controls="submenuTinTuc">
                    <i class="fas fa-caret-down me-2"></i>TIN TỨC
                </a>
                <div class="collapse show" id="submenuTinTuc">
                    <a asp-controller="News" asp-action="Category" asp-route-id="13" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>TIN NHÀ TRƯỜNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="14" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>BÁO CHÍ ĐƯA TIN VỀ TRƯỜNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="15" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>HƯỚNG NGHIỆP - DU HỌC - HỌC BỔNG
                    </a>
                </div>

                @* 2. THÔNG BÁO *@
                <a asp-controller="News" asp-action="Category" asp-route-id="2" class="list-group-item list-group-item-action text-primary fw-bold border-bottom">
                    <i class="fas fa-caret-right me-2"></i>THÔNG BÁO
                </a>

                @* 3. TUYỂN SINH 10 *@
                <a href="#submenuTuyenSinh" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="submenuTuyenSinh">
                    <i class="fas fa-caret-down me-2"></i>TUYỂN SINH 10
                </a>
                <div class="collapse" id="submenuTuyenSinh">
                    <a asp-controller="News" asp-action="Category" asp-route-id="16" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2026 - 2027
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="17" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2025 - 2026
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="18" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2024 - 2025
                    </a>
                </div>

                @* 4. NGUYỄN DU TRONG TÔI *@
                <a href="#submenuNguyenDu" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="submenuNguyenDu">
                    <i class="fas fa-caret-down me-2"></i>NGUYỄN DU TRONG TÔI
                </a>
                <div class="collapse" id="submenuNguyenDu">
                    <a asp-controller="News" asp-action="Category" asp-route-id="19" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>KẾ HOẠCH, HOẠT ĐỘNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="20" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>GIỚI THIỆU TỔ CHUYÊN MÔN
                    </a>
                </div>
            </div>
        </div>
        <img src="/images/banner-chinh(4).jpg" class="w-100 rounded shadow-sm mb-3" alt="Lịch tiếp dân">
    </div>

    @* --- CỘT GIỮA: SLIDE & TIN TỨC SỰ KIỆN --- *@
    <div class="col-md-6">
        <div id="schoolCarousel" class="carousel slide shadow-sm rounded overflow-hidden mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="/images/banner-chinh..jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
                <div class="carousel-item">
                    <img src="/images/banner-chinh(6).jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
                <div class="carousel-item">
                    <img src="/images/banner-chinh.jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#schoolCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#schoolCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

        <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
            <h5 class="text-primary fw-bold mb-0">TIN TỨC - SỰ KIỆN</h5>
            <a asp-controller="News" asp-action="Category" asp-route-id="1" class="btn btn-sm btn-outline-primary py-0" style="font-size: 12px;">Xem chi tiết >></a>
        </div>

        @if (Model.EventPosts != null && Model.EventPosts.Any())
        {
            foreach (var item in Model.EventPosts)
            {
                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-4">
                        <a asp-action="Details" asp-route-id="@item.Id">
                            <img src="@item.ImageUrl" class="img-fluid rounded border shadow-sm w-100" style="height: 120px; object-fit: cover;" onerror="this.src='/images/banner-khac.jpg'">
                        </a>
                    </div>
                    <div class="col-8">
                        <h6 class="fw-bold mb-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                        </h6>
                        <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")</small>
                        <p class="small text-secondary mt-1 text-truncate-2">@item.Summary</p>
                    </div>
                </div>
            }
        }
    </div>

    @* --- CỘT PHẢI: TIN MỚI NHẤT --- *@
    <div class="col-md-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <span class="fw-bold text-primary text-uppercase" style="font-size: 14px;">Tin Mới Nhất</span>
                <a asp-controller="News" asp-action="Category" asp-route-id="12" class="text-muted small text-decoration-none" style="font-size: 11px;">Xem tất cả</a>
            </div>
            <div class="card-body p-2">
                @if (Model.LatestPostsFromCategory != null && Model.LatestPostsFromCategory.Any())
                {
                    @foreach (var item in Model.LatestPostsFromCategory)
                    {
                        <div class="mb-2 border-bottom pb-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark small fw-bold d-block">@item.Title</a>
                            <span class="badge bg-light text-muted p-0" style="font-size: 10px;">@item.CreatedDate.ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* --- VIDEO & THÔNG BÁO --- *@
<div class="row mt-5">
    <div class="col-md-8">
        <div class="border-start border-4 border-primary ps-2 mb-3">
            <h5 class="text-primary fw-bold mb-0 text-uppercase">Video Clip nổi bật</h5>
        </div>
        <div class="ratio ratio-16x9 shadow-sm rounded overflow-hidden border">
            <iframe src="https://www.youtube.com/embed/FrlTL7nh_pI" title="YouTube video" allowfullscreen></iframe>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-center border-start border-4 border-danger ps-2 mb-3">
            <h5 class="text-danger fw-bold text-uppercase mb-0">Thông báo mới</h5>
            <a asp-controller="News" asp-action="Category" asp-route-id="6" class="text-danger small text-decoration-none" style="font-size: 12px;">Xem thêm >></a>
        </div>
        <div class="list-group list-group-flush shadow-sm bg-white rounded p-2">
            @if (Model.NewNotificationPosts != null && Model.NewNotificationPosts.Any())
            {
                @foreach (var item in Model.NewNotificationPosts)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action border-bottom py-2 px-1">
                        <h6 class="mb-1 text-dark small fw-bold text-truncate-2">@item.Title</h6>
                        <small class="text-muted" style="font-size: 11px;"><i class="far fa-calendar-alt me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </a>
                }
            }
        </div>
    </div>
</div>

@* --- CÔNG ĐOÀN & ĐOÀN THANH NIÊN --- *@
<div class="row mt-5">
    <div class="col-md-6 mb-4">
        <div class="p-3 bg-white border rounded shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                <h5 class="text-primary fw-bold mb-0 text-uppercase">Hoạt động Công đoàn</h5>
                <a asp-controller="News" asp-action="Category" asp-route-id="8" class="text-primary small text-decoration-none" style="font-size: 12px;">Xem thêm</a>
            </div>
            <div class="row">
                <div class="col-5">
                    <img src="/images/banner-chinh(4).jpg" class="img-fluid rounded border shadow-sm w-100" style="height:100px; object-fit:cover;">
                </div>
                <div class="col-7">
                    <ul class="list-unstyled small mb-0">
                        @foreach (var item in Model.UnionPosts) {
                            <li class="text-truncate mb-2 border-bottom pb-1">
                                <i class="fas fa-angle-right text-primary me-1"></i>
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="p-3 bg-white border rounded shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                <h5 class="text-success fw-bold mb-0 text-uppercase">Đoàn thanh niên</h5>
                <a asp-controller="News" asp-action="Category" asp-route-id="7" class="text-success small text-decoration-none" style="font-size: 12px;">Xem thêm</a>
            </div>
            <div class="row">
                <div class="col-5">
                    <img src="/images/banner-chinh(6).jpg" class="img-fluid rounded border shadow-sm w-100" style="height:100px; object-fit:cover;">
                </div>
                <div class="col-7">
                    <ul class="list-unstyled small mb-0">
                        @foreach (var item in Model.YouthUnionPosts) {
                            <li class="text-truncate mb-2 border-bottom pb-1">
                                <i class="fas fa-angle-right text-success me-1"></i>
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- THƯ VIỆN ẢNH (ĐÃ CẬP NHẬT ĐỂ LƯỚT ĐƯỢC) --- *@
<div class="mt-5 p-4 rounded shadow-sm bg-light">
    <h5 class="text-primary fw-bold border-bottom pb-2 mb-4 text-uppercase text-center">
        <i class="fas fa-camera-retro me-2"></i>Thư viện hình ảnh nhà trường
    </h5>
    
    <div class="school-gallery-slider">
        @if (Model.LatestPosts != null && Model.LatestPosts.Any())
        {
            foreach (var item in Model.LatestPosts) 
            {
                <div class="px-2">
                    <div class="gallery-container overflow-hidden rounded shadow-sm border border-white border-4">
                        <a asp-action="Details" asp-route-id="@item.Id">
                           <img src="@item.ImageUrl" 
                                 class="img-fluid w-100 hover-zoom-effect" 
                                 style="height:180px; object-fit:cover;" 
                                 alt="@item.Title"
                                 onerror="this.src='/images/banner-khac.jpg'">
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* --- QUICK LINKS: GIAO DIỆN MỚI + CHỨC NĂNG --- *@
<div class="row mt-5 mb-5 g-3">
    @* 1. CỔNG HỌC SINH *@
    <div class="col-md-3 col-6">
        <a asp-controller="Student" asp-action="Portal" class="text-decoration-none">
            <div class="quick-link-card-full border-blue shadow-sm bg-white h-100">
                <i class="fas fa-graduation-cap fa-2x color-blue mb-2"></i>
                <h6 class="fw-bold mb-0 text-dark">CỔNG HỌC SINH</h6>
            </div>
        </a>
    </div>

   @* 2. THƯ VIỆN SỐ *@
<div class="col-md-3 col-6">
    <a asp-controller="Student" asp-action="DigitalLibrary" class="text-decoration-none">
        <div class="quick-link-card-full border-green shadow-sm bg-white h-100">
            <i class="fas fa-book-open fa-2x color-green mb-2"></i>
            <h6 class="fw-bold mb-0 text-dark">THƯ VIỆN SỐ</h6>
        </div>
    </a>
</div>

@* 3. LỊCH CÔNG TÁC (Lịch học & Thi) *@
<div class="col-md-3 col-6">
    <a asp-controller="Student" asp-action="WorkSchedule" class="text-decoration-none">
        <div class="quick-link-card-full border-yellow shadow-sm bg-white h-100">
            <i class="fas fa-calendar-alt fa-2x color-yellow mb-2"></i>
            <h6 class="fw-bold mb-0 text-dark">LỊCH CÔNG TÁC</h6>
        </div>
    </a>
</div>

    @* 4. HỘP THƯ GÓP Ý *@
    <div class="col-md-3 col-6">
        <a asp-controller="Feedback" asp-action="Create" class="text-decoration-none">
            <div class="quick-link-card-full border-red shadow-sm bg-white h-100">
                <i class="fas fa-envelope-open-text fa-2x color-red mb-2"></i>
                <h6 class="fw-bold mb-0 text-dark">HỘP THƯ GÓP Ý</h6>
            </div>
        </a>
    </div>
</div> 

@section Scripts {
    <script>
        $(document).ready(function(){
            $('.school-gallery-slider').slick({
                dots: true,
                infinite: true,
                speed: 500,
                slidesToShow: 4,     
                slidesToScroll: 1,
                autoplay: true,
                autoplaySpeed: 3000,
                arrows: true,
                responsive: [
                    { breakpoint: 1024, settings: { slidesToShow: 3 } },
                    { breakpoint: 768, settings: { slidesToShow: 2 } },
                    { breakpoint: 480, settings: { slidesToShow: 1 } }
                ]
            });
        });
    </script>
}

<style>
    /* 1. Đồng bộ màu đặc trưng */
    :root {
        --nd-blue: #0056b3;
        --nd-light-blue: #e7f1ff;
        --nd-green: #198754;
        --nd-yellow: #ffc107;
        --nd-red: #dc3545;
    }

    /* 2. Làm đẹp khối DANH MỤC */
    .card-header.bg-primary { background-color: var(--nd-blue) !important; letter-spacing: 1px; }
    .list-group-item-action.text-primary { color: var(--nd-blue) !important; transition: all 0.3s; }
    .list-group-item-action:hover { background-color: var(--nd-light-blue); padding-left: 1.5rem !important; }

    /* 3. Làm đẹp tiêu đề các khối */
    h5.text-primary.border-bottom, h5.text-danger, h5.text-success {
        position: relative;
        padding-bottom: 10px;
        margin-bottom: 20px !important;
    }
    h5.text-primary.border-bottom::after {
        content: ""; position: absolute; bottom: -2px; left: 0; width: 80px; height: 3px; background-color: var(--nd-blue);
    }

    /* 4. Tinh chỉnh Slider & Tiện ích */
    .slick-prev:before, .slick-next:before { color: var(--nd-blue) !important; font-size: 25px; }
    .slick-dots li button:before { color: var(--nd-blue) !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; height: 2.8em; }
    .hover-zoom-effect { transition: transform .4s ease; cursor: pointer; }
    .hover-zoom-effect:hover { transform: scale(1.08); }

    /* 5. GIAO DIỆN QUICK LINKS FULL BORDER */
    .quick-link-card-full {
        padding: 20px;
        text-align: center;
        border-radius: 12px;
        border-width: 3px;
        border-style: solid;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .quick-link-card-full:hover { transform: translateY(-8px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; background-color: #fcfcfc !important; }
    
    .border-blue { border-color: var(--nd-blue); }
    .border-green { border-color: var(--nd-green); }
    .border-yellow { border-color: var(--nd-yellow); }
    .border-red { border-color: var(--nd-red); }
    
    .color-blue { color: var(--nd-blue); }
    .color-green { color: var(--nd-green); }
    .color-yellow { color: var(--nd-yellow); }
    .color-red { color: var(--nd-red); }
</style>