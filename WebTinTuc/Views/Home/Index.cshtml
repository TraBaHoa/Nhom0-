@model IEnumerable<WebTinTuc.Data.Entities.Post>

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-bold">DANH MỤC</div>
            <div class="list-group list-group-flush">
                <a href="#" class="list-group-item list-group-item-action text-primary small border-bottom"><i class="fas fa-caret-right me-2"></i>TIN TỨC</a>
                <a href="#" class="list-group-item list-group-item-action text-primary small border-bottom"><i class="fas fa-caret-right me-2"></i>THÔNG BÁO</a>
                <a href="#" class="list-group-item list-group-item-action text-primary small border-bottom"><i class="fas fa-caret-right me-2"></i>TUYỂN SINH 10</a>
                <a href="#" class="list-group-item list-group-item-action text-primary small border-bottom"><i class="fas fa-caret-right me-2"></i>NGUYỄN DU TRONG TÔI</a>
            </div>
        </div>
        <img src="~/images/banner-chinh(4).jpg" class="w-100 rounded shadow-sm mb-3" alt="Lịch tiếp dân">
        </div>

        <div class="col-md-6">
            <div id="schoolCarousel" class="carousel slide shadow-sm rounded overflow-hidden mb-4" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/images/banner-chinh..jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/banner-chinh(6).jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                            </div>
                            <div class="carousel-item">
                                <img src="~/images/banner-chinh.jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                                </div>
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#schoolCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#schoolCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon"></span>
                            </button>
                        </div>

                        <h5 class="text-primary fw-bold border-bottom pb-2 mb-3">TIN TỨC - SỰ KIỆN</h5>
                        @foreach (var item in Model)
                        {
                            <div class="row mb-4 border-bottom pb-3">
                                <div class="col-4">
                                    <a asp-action="Details" asp-route-id="@item.Id">
                                        <img src="@item.ImageUrl" class="img-fluid rounded border shadow-sm" onerror="this.src='~/images/banner-khac.jpg'">
                                    </a>
                                </div>
                                <div class="col-8">
                                    <h6 class="fw-bold mb-1">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                                    </h6>
                                    <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")</small>
                                    <p class="small text-secondary mt-1">@item.Summary</p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="col-md-3">
                        <div class="card mb-3 shadow-sm border-0">
                            <div class="card-header bg-light fw-bold text-primary">TIN MỚI NHẤT</div>
                            <div class="card-body p-2">
                                @foreach (var news in Model.Take(3))
                                {
                                    <div class="mb-2 border-bottom pb-1">
                                        <a asp-action="Details" asp-route-id="@news.Id" class="text-decoration-none text-dark small fw-bold d-block">@news.Title</a>
                                        <span class="badge bg-light text-muted p-0" style="font-size: 10px;">@news.CreatedDate.ToString("dd/MM/yyyy")</span>
                                    </div>
                                }
                            </div>
                        </div>
        
                        <div class="d-grid gap-2">
                            <button class="btn btn-warning fw-bold text-white shadow-sm mb-1"><i class="far fa-calendar-check me-2"></i>THỜI KHÓA BIỂU</button>
                            <button class="btn btn-primary fw-bold shadow-sm mb-1"><i class="fas fa-flag me-2"></i>ĐOÀN TRƯỜNG</button>
                            <button class="btn btn-danger fw-bold shadow-sm"><i class="fas fa-tv me-2"></i>ENDEE CHANNEL</button>
                        </div>
                    </div>
                </div>