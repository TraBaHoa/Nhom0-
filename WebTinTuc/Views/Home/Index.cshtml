@model WebTinTuc.Models.ViewModels.HomeViewModel

<div class="row">
    @* --- CỘT TRÁI: DANH MỤC --- *@
    <div class="col-md-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-bold">DANH MỤC</div>
            <div class="list-group list-group-flush shadow-sm">
                
                <a href="#submenuTinTuc" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="true" aria-controls="submenuTinTuc">
                    <i class="fas fa-caret-down me-2"></i>TIN TỨC
                </a>
                <div class="collapse show" id="submenuTinTuc">
                    <a asp-controller="News" asp-action="Category" asp-route-id="1" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>TIN NHÀ TRƯỜNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="2" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>BÁO CHÍ ĐƯA TIN VỀ TRƯỜNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="3" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>HƯỚNG NGHIỆP - DU HỌC - HỌC BỔNG
                    </a>
                </div>

                <a asp-controller="News" asp-action="Category" asp-route-id="4" class="list-group-item list-group-item-action text-primary small border-bottom">
                    <i class="fas fa-caret-right me-2"></i>THÔNG BÁO
                </a>

                <a href="#submenuTuyenSinh" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="submenuTuyenSinh">
                    <i class="fas fa-caret-down me-2"></i>TUYỂN SINH 10
                </a>
                <div class="collapse" id="submenuTuyenSinh">
                    <a asp-controller="News" asp-action="Category" asp-route-id="5" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2026 - 2027
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="6" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2025 - 2026
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="7" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>NĂM HỌC 2024 - 2025
                    </a>
                </div>

                <a href="#submenuNguyenDu" class="list-group-item list-group-item-action text-primary fw-bold border-bottom"
                       data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="submenuNguyenDu">
                    <i class="fas fa-caret-down me-2"></i>NGUYỄN DU TRONG TÔI
                </a>
                <div class="collapse" id="submenuNguyenDu">
                    <a asp-controller="News" asp-action="Category" asp-route-id="8" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>KẾ HOẠCH, HOẠT ĐỘNG
                    </a>
                    <a asp-controller="News" asp-action="Category" asp-route-id="9" class="list-group-item list-group-item-action ps-4 border-bottom text-secondary" style="font-size: 13px;">
                        <i class="fas fa-angle-right me-2"></i>GIỚI THIỆU TỔ CHUYÊN MÔN
                    </a>
                </div>
            </div>
        </div>
        <img src="~/images/banner-chinh(4).jpg" class="w-100 rounded shadow-sm mb-3" alt="Lịch tiếp dân">
    </div>

    @* --- CỘT GIỮA: SLIDE & TIN TỨC SỰ KIỆN --- *@
    <div class="col-md-6">
        <div id="schoolCarousel" class="carousel slide shadow-sm rounded overflow-hidden mb-4" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/images/banner-chinh..jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
                <div class="carousel-item">
                    <img src="~/images/banner-chinh(6).jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
                <div class="carousel-item">
                    <img src="~/images/banner-chinh.jpg" class="d-block w-100" style="height: 350px; object-fit: cover;">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#schoolCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#schoolCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

        <h5 class="text-primary fw-bold border-bottom pb-2 mb-3">TIN TỨC - SỰ KIỆN</h5>
        @if (Model.EventPosts != null && Model.EventPosts.Any())
        {
            foreach (var item in Model.EventPosts)
            {
                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-4">
                        <a asp-action="Details" asp-route-id="@item.Id">
                            <img src="@item.ImageUrl" class="img-fluid rounded border shadow-sm w-100" style="height: 120px; object-fit: cover;" onerror="this.src='/images/banner-khac.jpg'">
                        </a>
                    </div>
                    <div class="col-8">
                        <h6 class="fw-bold mb-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Posts" asp-action="Edit" asp-route-id="@item.Id" class="ms-2 badge bg-warning text-dark text-decoration-none">
                                    <i class="fas fa-edit"></i> Sửa
                                </a>
                            }
                        </h6>
                        <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")</small>
                        <p class="small text-secondary mt-1 text-truncate-2">@item.Summary</p>
                    </div>
                </div>
            }
        }
    </div>

    @* --- CỘT PHẢI: TIN MỚI NHẤT --- *@
    <div class="col-md-3">
        <div class="card mb-3 shadow-sm border-0">
            <div class="card-header bg-light fw-bold text-primary">TIN MỚI NHẤT</div>
            <div class="card-body p-2">
                @if (Model.LatestPosts != null && Model.LatestPosts.Any())
                {
                    @foreach (var item in Model.LatestPosts)
                    {
                        <div class="mb-2 border-bottom pb-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark small fw-bold d-block">@item.Title</a>
                            <span class="badge bg-light text-muted p-0" style="font-size: 10px;">@item.CreatedDate.ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>         

<div class="row mt-5">
    <div class="col-md-8">
        <div class="border-start border-4 border-primary ps-2 mb-3">
            <h5 class="text-primary fw-bold mb-0 text-uppercase">Video Clip nổi bật</h5>
        </div>
        <div class="ratio ratio-16x9 shadow-sm rounded overflow-hidden border">
            <iframe src="https://www.youtube.com/embed/tbnzOnD96nc" title="YouTube video" allowfullscreen></iframe>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="border-start border-4 border-danger ps-2 mb-3">
            <h5 class="text-danger fw-bold">THÔNG BÁO MỚI</h5>
        </div>
        <div class="list-group list-group-flush">
            @if (Model.LatestPosts != null)
            {
                @foreach (var item in Model.NotificationPosts)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action border-bottom py-3 px-0">
                        <h6 class="mb-1 text-dark small fw-bold text-truncate-2">@item.Title</h6>
                        <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </a>
                }
            }
        </div>
    </div>
</div>

<div class="row mt-5">
    @* Hoạt động Công đoàn *@
    <div class="col-md-6 mb-4">
        <div class="p-3 bg-white border rounded shadow-sm h-100">
            <h5 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase">Hoạt động Công đoàn</h5>
            <div class="row">
                <div class="col-5">
                    <img src="~/images/banner-chinh(4).jpg" class="img-fluid rounded border shadow-sm w-100" style="height:100px; object-fit:cover;">
                </div>
                <div class="col-7">
                    <ul class="list-unstyled small mb-0">
                        @if (Model.UnionPosts != null)
                        {
                            foreach (var item in Model.UnionPosts.Take(3)) {
                                <li class="text-truncate mb-2 border-bottom pb-1">
                                    <i class="fas fa-angle-right text-primary me-1"></i>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @* Đoàn thanh niên *@
    <div class="col-md-6 mb-4">
        <div class="p-3 bg-white border rounded shadow-sm h-100">
            <h5 class="text-success fw-bold border-bottom pb-2 mb-3 text-uppercase">Đoàn thanh niên</h5>
            <div class="row">
                <div class="col-5">
                    <img src="~/images/banner-chinh(6).jpg" class="img-fluid rounded border shadow-sm w-100" style="height:100px; object-fit:cover;">
                </div>
                <div class="col-7">
                    <ul class="list-unstyled small mb-0">
                        @if (Model.YouthUnionPosts != null)
                        {
                            foreach (var item in Model.YouthUnionPosts.Take(3)) {
                                <li class="text-truncate mb-2 border-bottom pb-1">
                                    <i class="fas fa-angle-right text-success me-1"></i>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none">@item.Title</a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-5 p-4 rounded shadow-sm bg-light">
    <h5 class="text-primary fw-bold border-bottom pb-2 mb-4 text-uppercase text-center">
        <i class="fas fa-camera-retro me-2"></i>Thư viện hình ảnh nhà trường
    </h5>
    <div class="row g-3">
        @if (Model.LatestPosts != null && Model.LatestPosts.Any())
        {
           
            foreach (var item in Model.LatestPosts.Take(5)) 
            {
                <div class="col-md-3 col-6">
                    <div class="gallery-container overflow-hidden rounded shadow-sm border border-white border-4">
                        <a href="@Url.Action("Details", "Posts", new { id = item.Id })">
                            <img src="@item.ImageUrl" 
                                 class="img-fluid w-100 hover-zoom-effect" 
                                 style="height:180px; object-fit:cover; transition: transform .3s;" 
                                 alt="@item.Title"
                                 onerror="this.src='/images/banner-khac.jpg'">
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted">Đang cập nhật hình ảnh...</div>
        }
    </div>
</div>

<style>
    .hover-zoom-effect:hover {
        transform: scale(1.1);
    }
    .gallery-container {
        cursor: pointer;
    }
</style>

<div class="row mt-5 mb-5 g-3">
    @* --- QUICK LINKS --- *@
    <div class="col-md-3 col-6">
        <div class="quick-link-card p-3 text-center border-top border-4 border-primary shadow-sm bg-white rounded h-100">
            <i class="fas fa-graduation-cap fa-2x text-primary mb-2"></i>
            <h6 class="fw-bold mb-0">CỔNG HỌC SINH</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-link-card p-3 text-center border-top border-4 border-success shadow-sm bg-white rounded h-100">
            <i class="fas fa-book-open fa-2x text-success mb-2"></i>
            <h6 class="fw-bold mb-0">THƯ VIỆN SỐ</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-link-card p-3 text-center border-top border-4 border-warning shadow-sm bg-white rounded h-100">
            <i class="fas fa-calendar-alt fa-2x text-warning mb-2"></i>
            <h6 class="fw-bold mb-0">LỊCH CÔNG TÁC</h6>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-link-card p-3 text-center border-top border-4 border-danger shadow-sm bg-white rounded h-100">
            <i class="fas fa-envelope-open-text fa-2x text-danger mb-2"></i>
            <h6 class="fw-bold mb-0">HỘP THƯ GÓP Ý</h6>
        </div>
    </div>
</div>

<style>
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .hover-zoom-effect { transition: transform .4s ease; cursor: pointer; }
    .hover-zoom-effect:hover { transform: scale(1.08); }
    .gallery-container { position: relative; background-color: #ddd; }
    .quick-link-card { transition: all 0.3s ease; cursor: pointer; border-bottom: 1px solid #eee; }
    .quick-link-card:hover { transform: translateY(-5px); background-color: #f1f1f1; box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>