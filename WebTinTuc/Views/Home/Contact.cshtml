                </div>
                <div class="card-body">
                    <div class="mb-3 d-flex align-items-start">
                        <i class="fas fa-map-marker-alt text-primary mt-1 me-3"></i>
                        <div>
                            <strong>Địa chỉ:</strong><br>
                            XXI Đồng Nai, Phường 15, Quận 10, TP. Hồ Chí Minh
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-start">
                        <i class="fas fa-phone-alt text-primary mt-1 me-3"></i>
                        <div>
                            <strong>Số điện thoại:</strong><br>
                            028.3864.1373
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-start">
                        <i class="fas fa-envelope text-primary mt-1 me-3"></i>
                        <div>
                            <strong>Email:</strong><br>
                            c3nguyendu.tphcm@moet.edu.vn
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-start">
                        <i class="comment-dots fas fa-comment-dots text-primary mt-1 me-3"></i>
                        <div>
                            <strong>Zalo hỗ trợ:</strong><br>
                            <a href="https://zalo.me/02838641373" target="_blank" class="text-decoration-none">Nhấn để nhắn tin Zalo</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
    <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-success text-white fw-bold">
            <i class="fas fa-map-marked-alt me-2"></i>VỊ TRÍ TRÊN BẢN ĐỒ
        </div>
        <div class="card-body p-0 overflow-hidden">
            @* Vinh thay đoạn iframe dưới đây *@
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4566373797966!2d106.66019467583804!3d10.7762955591953!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f256cdc183d%3A0x628597853a633a77!2zVHLGsOG7nW5nIFRIUFQgTmd1eeG7…RuIER1!5e0!3m2!1svi!2s!4v1712745000000!5m2!1svi!2s"
                style="width: 100%; border: 0; min-height: 400px;"
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</div>
    </div>
</div>
<style>
    /* 1. Hiệu ứng phóng to nhẹ và đổi màu khi rê chuột vào các khối liên hệ */
    .card-body .d-flex {
        transition: all 0.3s ease;
        padding: 10px;
        border-radius: 8px;
    }

    .card-body .d-flex:hover {
        background-color: #f0f7ff; /* Màu xanh cực nhạt */
        transform: translateX(10px); /* Nhích sang phải một chút */
    }

    /* 2. Hiệu ứng rung nhẹ cho icon Zalo để thu hút sự chú ý */
    .comment-dots {
        animation: pulse-zalo 2s infinite;
    }

    @@keyframes pulse-zalo {
        0% { transform: scale(1); }
        50% { transform: scale(1.2); color: #0068ff; }
        100% { transform: scale(1); }
    }

    /* 3. Làm đẹp thẻ bản đồ */
    .overflow-hidden {
        border-bottom-left-radius: 0.375rem;
        border-bottom-right-radius: 0.375rem;
    }
    
    /* 4. Đảm bảo nút Zalo trông giống nút bấm hơn */
    .zalo-link {
        display: inline-block;
        padding: 5px 12px;
        background-color: #0068ff;
        color: white !important;
        border-radius: 20px;
        font-size: 0.85rem;
        transition: background 0.3s;
    }
    .zalo-link:hover {
        background-color: #0051c7;
        box-shadow: 0 4px 8px rgba(0,104,255,0.3);
    }
</style>