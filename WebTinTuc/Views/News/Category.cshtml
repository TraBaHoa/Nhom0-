@model IEnumerable<WebTinTuc.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh sách tin tức";
}

<div class="container mt-4 mb-5">
    <div class="border-start border-4 border-primary ps-2 mb-4">
        <h4 class="text-primary fw-bold mb-0 text-uppercase">Danh sách tin bài</h4>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-12">
                    <div class="card flex-md-row mb-4 shadow-sm h-md-250 border-0 border-bottom pb-3">
                        <img class="card-img-right flex-auto d-none d-md-block rounded"
                             style="width: 250px; height: 160px; object-fit: cover;"
                             src="@item.ImageUrl"
                             onerror="this.src='/images/banner-khac.jpg'"
                             alt="@item.Title">

                        <div class="card-body d-flex flex-column align-items-start py-0 pe-0 ps-3">
                            <h5 class="mb-2 fw-bold">
                                <a class="text-dark text-decoration-none" asp-controller="News" asp-action="Details" asp-route-id="@item.Id">
                                    @item.Title
                                </a>
                            </h5>
                            <div class="mb-2 text-muted small">
                                <i class="far fa-calendar-alt me-1"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                            </div>
                            <p class="card-text mb-auto text-secondary text-truncate-3">
                                @item.Summary
                            </p>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary mt-2">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info shadow-sm">
            <i class="fas fa-info-circle me-2"></i> Hiện tại chưa có bài viết nào trong chuyên mục này.
        </div>
    }
</div>

<style>
    /* CSS giúp cắt bớt chữ nếu đoạn tóm tắt quá dài (tối đa 3 dòng) */
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>