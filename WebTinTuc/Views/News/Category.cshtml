@model IEnumerable<WebTinTuc.Data.Entities.Post>

<div class="container mt-4">
    @* Tiêu đề sẽ tự thay đổi theo chuyên mục bạn bấm *@
    <div class="border-start border-4 border-primary ps-2 mb-3">
        <h2 class="text-primary fw-bold mb-0 text-uppercase">| @ViewBag.CategoryName</h2>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" onerror="this.src='/images/banner-khac.jpg'">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark">@item.Title</h6>
                            <p class="small text-secondary text-truncate-2">@item.Summary</p>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center my-5">
                <p class="text-muted">Không có bài viết nào trong chuyên mục này.</p>
            </div>
        }
    </div>
</div>