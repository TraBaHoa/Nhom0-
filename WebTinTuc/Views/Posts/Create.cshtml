@model WebTinTuc.Models.ViewModels.PostViewModel

@{
    ViewData["Title"] = "Tạo Bài Viết Mới";
}

<h1 class="text-primary">Đăng Bài Viết</h1>
<hr />

<div class="row">
    <div class="col-md-9">
        @* Chỉ sử dụng MỘT thẻ form duy nhất bao quanh tất cả các ô nhập liệu *@
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label fw-bold">Tiêu đề bài viết</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="control-label fw-bold">Chuyên mục</label>
                <select asp-for="CategoryId" class="form-control"
                        asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                    <option value="">-- Chọn chuyên mục hiển thị --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            @* 1. Ô nhập Ảnh chính (Thumbnail) - Dùng ImageFile của ViewModel *@
            <div class="form-group mb-3">
                <label asp-for="ImageFile" class="control-label fw-bold">Ảnh chính (Thumbnail)</label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            @* 2. Ô nhập Bộ sưu tập ảnh (Nhiều ảnh) - Dùng MoreImages của ViewModel *@
            <div class="form-group mb-3 border p-3 rounded bg-light">
                <label class="control-label fw-bold text-success">Bộ sưu tập ảnh (Nhiều ảnh)</label>
                <input type="file" name="moreImages" class="form-control" accept="image/*" multiple />
                <small class="text-muted">Bạn có thể giữ phím Ctrl để chọn nhiều ảnh cùng lúc.</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Summary" class="control-label fw-bold">Tóm tắt ngắn</label>
                <textarea asp-for="Summary" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Summary" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Content" class="control-label fw-bold">Nội dung chi tiết</label>
                <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="form-group mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="fas fa-paper-plane me-1"></i> Đăng bài ngay
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm">
                    <i class="fas fa-undo me-1"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}