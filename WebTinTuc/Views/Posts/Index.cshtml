@model IEnumerable<WebTinTuc.Data.Entities.Post>
@{
    ViewData["Title"] = "Quản lý Bài Viết";
}

<h1 class="text-primary">Danh Sách Bài Viết</h1>

<p>
    <a asp-action="Create" class="btn btn-success">
        <i class="fa fa-plus"></i> Tạo bài viết mới
    </a>
</p>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th style="width: 25%">Tiêu đề</th>
            <th style="width: 15%">Hình ảnh</th>
            <th style="width: 15%">Chuyên mục</th>
            <th style="width: 15%">Ngày đăng</th>
            <th style="width: 15%">Tóm tắt</th>
            <th style="width: 15%">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">@Html.DisplayFor(modelItem => item.Title)</td>
                <td class="text-center">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" style="width:80px; height:60px; object-fit:cover; border-radius:5px;" alt="Ảnh bài viết" />
                    }
                    else
                    {
                        <span class="text-muted small">Không ảnh</span>
                    }
                </td>
                <td>
                    @if (item.Category != null)
                    {
                        <span class="badge bg-info text-dark">
                            @item.Category.Name
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Chưa phân mục</span>
                    }
                </td>
                <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td title="@item.Summary">
                    @* Di chuột vào để xem đầy đủ *@
                    @if (!string.IsNullOrEmpty(item.Summary))
                    {
                        @(item.Summary.Length > 50 ? item.Summary.Substring(0, 50) + "..." : item.Summary)
                    }
                </td>
                <td>
                    <div class="btn-group shadow-sm">
                        <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-warning px-3"
                               title="Sửa"
                               style="border-radius: 5px 0 0 5px; transition: all 0.3s;">
                            <i class="fas fa-edit me-1"></i> Sửa
                        </a>
    
                        <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-info px-3"
                               title="Xem chi tiết"
                               style="transition: all 0.3s;">
                            <i class="fas fa-eye me-1"></i> Xem
                        </a>
    
                        <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger px-3"
                               title="Xóa"
                               style="border-radius: 0 5px 5px 0; transition: all 0.3s;">
                            <i class="fas fa-trash-alt me-1"></i> Xóa
                        </a>
                    </div>

                    <style>
                           /* Hiệu ứng khi di chuột vào nút */
                           .btn-group .btn:hover {
                           transform: translateY(-2px);
                           box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                           z-index: 2; /* Để phần shadow không bị nút bên cạnh che mất */
                          }
                    </style>
                </td>
            </tr>
        }
    </tbody>
</table>