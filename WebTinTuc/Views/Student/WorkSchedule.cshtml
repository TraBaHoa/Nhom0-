@using WebTinTuc.Models.ViewModels
@model WorkScheduleViewModel
@{
    ViewData["Title"] = "Lịch công tác tuần";
}

<div class="container mt-4 mb-5">
    @* Tiêu đề *@
    <div class="border-start border-5 border-warning ps-3 mb-4">
        <h3 class="text-dark fw-bold text-uppercase mb-0">Lịch Công Tác Tuần</h3>
        <p class="text-muted small">Cập nhật lịch họp, sự kiện và hoạt động của nhà trường.</p>
    </div>

    @* BỘ LỌC CHỨC NĂNG - Đã đổi sang Lịch chọn ngày thực *@
    <form asp-action="WorkSchedule" method="get" id="filterForm">
        <div class="card border-0 shadow-sm mb-4 bg-light">
            <div class="card-body d-flex flex-wrap gap-3 align-items-center">
                <div class="flex-grow-1">
                    <label class="small fw-bold text-muted">Xem lịch theo ngày:</label>
                    @* Ô chọn ngày thực tế *@
                    <input type="date" name="date" 
                           value="@Model.SelectedDate.ToString("yyyy-MM-dd")" 
                           class="form-control form-control-sm border-0 shadow-sm"
                           onchange="document.getElementById('filterForm').submit()">
                    <small class="text-info mt-1 d-block" style="font-size: 0.75rem;">
                        <i class="fas fa-info-circle me-1"></i>
                        Hệ thống sẽ hiển thị lịch của cả tuần chứa ngày bạn chọn.
                    </small>
                </div>
                <div>
                    <label class="small fw-bold text-muted">Khối lớp:</label>
                    <div class="btn-group btn-group-sm d-block shadow-sm">
                        <button type="submit" name="grade" value="Tất cả" class="btn btn-outline-primary @(Model.SelectedGrade == "Tất cả" ? "active" : "")">Tất cả</button>
                        <button type="submit" name="grade" value="Khối 10" class="btn btn-outline-primary @(Model.SelectedGrade == "Khối 10" ? "active" : "")">Khối 10</button>
                        <button type="submit" name="grade" value="Khối 11" class="btn btn-outline-primary @(Model.SelectedGrade == "Khối 11" ? "active" : "")">Khối 11</button>
                        <button type="submit" name="grade" value="Khối 12" class="btn btn-outline-primary @(Model.SelectedGrade == "Khối 12" ? "active" : "")">Khối 12</button>
                    </div>
                </div>
                <div class="mt-3 mt-md-0 d-flex gap-2">
                    <button type="button" class="btn btn-success btn-sm px-3 shadow-sm" onclick="exportExcel()">
                        <i class="fas fa-file-excel me-2"></i>Xuất Excel
                    </button>
                    <button type="button" class="btn btn-danger btn-sm px-3 shadow-sm" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>In lịch
                    </button>
                </div>
            </div>
        </div>
    </form>

    @* BẢNG LỊCH CÔNG TÁC *@
    <div class="table-responsive shadow-sm rounded border">
        <table class="table table-bordered align-middle mb-0 bg-white" id="scheduleTable">
            <thead class="text-center" style="background-color: #ffc107;">
                <tr>
                    <th style="width: 15%;" class="py-3">Thứ / Ngày</th>
                    <th style="width: 42.5%;">Sáng (7:30 - 11:30)</th>
                    <th style="width: 42.5%;">Chiều (13:30 - 17:00)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Posts != null && Model.Posts.Any())
                {
                    foreach (var item in Model.Posts)
                    {
                        <tr>
                            <td class="text-center fw-bold bg-light py-4">
                                @item.Title <br />
                                <span class="text-muted small fw-normal">@item.CreatedDate.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td class="ps-3 border-start border-4 border-info">
                                @Html.Raw(item.Summary)
                            </td>
                            <td class="ps-3">
                                @Html.Raw(item.Content)
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted italic">
                            <i class="fas fa-calendar-times fa-3x mb-3"></i>
                            <p>Không tìm thấy lịch trực cho ngày @Model.SelectedDate.ToString("dd/MM/yyyy") của @Model.SelectedGrade.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function exportExcel() {
            alert("Đang chuẩn bị tệp Excel lịch công tác...");
        }
    </script>
}

<style>
    /* Giữ nguyên các Style cũ của bạn */
    .table thead th { vertical-align: middle; border: none; font-weight: bold; }
    .table tbody td { padding: 1.25rem 0.75rem; transition: background 0.2s; }
    .table tbody tr:hover td { background-color: #fffdf5 !important; }
    
    @@media print {
        header, footer, .btn, label, .card, .alert, .border-start, #filterForm { display: none !important; }
        .container { max-width: 100% !important; width: 100% !important; margin: 0 !important; padding: 0 !important; }
        .table { width: 100% !important; border: 1px solid #000 !important; }
        .table-responsive { overflow: visible !important; }
    }
</style>