@model WebTinTuc.Data.Entities.Feedback

@{
    ViewData["Title"] = "Xác nhận xóa góp ý";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 text-uppercase">
                        <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa góp ý
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning border-0 shadow-sm">
                        <i class="fas fa-info-circle me-2"></i>
                        Vinh có chắc chắn muốn xóa vĩnh viễn góp ý này không? Hành động này không thể hoàn tác.
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Người gửi:</div>
                        <div class="col-sm-9 fw-bold text-dark">@Model.FullName</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold text-muted">Ngày gửi:</div>
                        <div class="col-sm-9 text-dark">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm:ss")</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-3 fw-bold text-muted">Nội dung:</div>
                        <div class="col-sm-9">
                            <div class="p-3 bg-light rounded border italic">
                                "@Model.Content"
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary px-4">
                            <i class="fas fa-times me-2"></i>Hủy bỏ
                        </a>
                        
                        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash-alt me-2"></i>Xác nhận Xóa
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light { background-color: #f8f9fa !important; }
    .italic { font-style: italic; color: #555; }
</style>