@model WebTinTuc.Data.Entities.Feedback

@{
    ViewData["Title"] = "Chi tiết góp ý";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Danh sách góp ý</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="text-primary fw-bold mb-0">
                <i class="fas fa-info-circle me-2"></i>THÔNG TIN GÓP Ý CHI TIẾT
            </h5>
            <div>
                @if (!Model.IsRead)
                {
                    <span class="badge bg-danger">Chưa đọc</span>
                }
                else
                {
                    <span class="badge bg-success">Đã xử lý</span>
                }
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="text-muted small text-uppercase fw-bold">Người gửi</label>
                    <p class="fs-5 fw-bold text-dark border-bottom pb-2">@Model.FullName</p>
                </div>
                <div class="col-md-6">
                    <label class="text-muted small text-uppercase fw-bold">Thời gian gửi</label>
                    <p class="fs-5 text-dark border-bottom pb-2">
                        <i class="far fa-calendar-alt me-2"></i>@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm:ss")
                    </p>
                </div>
            </div>

            <div class="mb-4">
                <label class="text-muted small text-uppercase fw-bold">Nội dung góp ý</label>
                <div class="p-3 bg-light rounded border mt-2" style="min-height: 150px; white-space: pre-wrap;">
                    @Model.Content
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>
                
                <div class="btn-group">
                    @if (!Model.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-success me-2">
                                <i class="fas fa-check me-2"></i>Đánh dấu đã đọc
                            </button>
                        </form>
                    }
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
                          onsubmit="return confirm('Vinh có chắc chắn muốn xóa góp ý này?');">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt me-2"></i>Xóa góp ý
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light { background-color: #f8f9fa !important; }
    .breadcrumb-item a { text-decoration: none; color: #6c757d; }
    .breadcrumb-item a:hover { color: #0d6efd; }
</style>