@model IEnumerable<WebTinTuc.Data.Entities.Feedback>

@{
    ViewData["Title"] = "Quản lý Góp ý - Phản hồi";
    Layout = "_LayoutAdmin"; 
}

<div class="container-fluid mt-4">
    @* --- Hiển thị thông báo kết quả --- *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-3">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="text-primary fw-bold mb-0 text-uppercase">
                <i class="fas fa-comments me-2"></i>Danh sách góp ý từ người dùng
            </h5>
            <span class="badge bg-info text-dark">Tổng số: @Model.Count()</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 5%">#</th>
                            <th style="width: 20%">Người gửi</th>
                            <th style="width: 40%">Nội dung góp ý</th>
                            <th style="width: 15%">Ngày gửi</th>
                            <th style="width: 10%">Trạng thái</th>
                            <th class="text-center" style="width: 10%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            foreach (var item in Model)
                            {
                                @* Dòng nào chưa đọc sẽ có màu nền cảnh báo nhẹ *@
                                <tr class="@(item.IsRead ? "" : "table-warning")">
                                    <td class="ps-4 fw-bold">@stt</td>
                                    <td><div class="fw-bold text-dark">@item.FullName</div></td>
                                    <td>
                                        <p class="mb-0 text-truncate" style="max-width: 400px;" title="@item.Content">
                                            @item.Content
                                        </p>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            <i class="far fa-clock me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </td>
                                    <td>
                                        @if (item.IsRead)
                                        {
                                            <span class="badge bg-success-soft text-success border border-success px-2">Đã xem</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger text-white px-2">Mới</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @* Nút xóa trỏ về trang xác nhận (GET Delete) *@
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                stt++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3"></i>
                                    <p>Hiện chưa có góp ý nào được gửi đến.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background-color: #e8f5e9; }
    .table-warning { background-color: #fff9e6 !important; }
    .table thead th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; border-top: none; }
    .btn-group .btn { padding: 0.25rem 0.6rem; }
    .text-truncate { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
</style>