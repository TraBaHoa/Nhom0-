@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
    // Đảm bảo Layout trỏ đúng về trang chủ của trường để giữ Header màu xanh đặc trưng
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<style>
    /* CSS được đặt sau các chỉ thị Razor để tránh lỗi RZ3906 */
    .login-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
        padding: 20px;
    }

    .login-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        max-width: 950px;
        width: 100%;
        display: flex;
        flex-wrap: wrap;
    }

    .login-sidebar {
        background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
        color: white;
        padding: 40px;
        flex: 1;
        min-width: 300px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .login-sidebar img {
        width: 140px;
        margin-bottom: 20px;
        filter: drop-shadow(0 5px 15px rgba(0,0,0,0.2));
    }

    .login-main {
        padding: 50px;
        flex: 1.3;
        min-width: 350px;
    }

    .btn-login {
        background: #007bff;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login:hover {
        background: #0056b3;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,123,255,0.3);
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-sidebar">
            <img src="~/images/logo-nguyendu.png" alt="Logo">
            <h3 class="fw-bold mt-2">THPT NGUYỄN DU</h3>
            <p class="opacity-75 small">Hệ thống quản trị nội bộ<br>Quận 10, TP. Hồ Chí Minh</p>
        </div>

        <div class="login-main">
            <h2 class="fw-bold text-dark mb-2">Đăng nhập</h2>
            <p class="text-muted mb-4 small">Vui lòng sử dụng tài khoản được cấp để truy cập</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email công tác</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Mật khẩu" />
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label small text-muted">Ghi nhớ tôi</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-login mb-4 text-white">XÁC NHẬN ĐĂNG NHẬP</button>

                <div class="text-center pt-2">
                    <p class="small text-muted mb-0">
                        Chưa có quyền quản trị? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none">Đăng ký tại đây</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}