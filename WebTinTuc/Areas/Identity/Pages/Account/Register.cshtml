@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        @* Cột chứa Form Đăng ký *@
        <div class="col-md-5 border p-4 shadow-sm rounded-4 bg-white">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div class="text-center mb-4">
                    <h2 class="text-primary fw-bold">TẠO TÀI KHOẢN</h2>
                    <p class="text-muted small">Cổng thông tin điện tử THPT Nguyễn Du</p>
                </div>
                <hr class="text-primary" />
                
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control rounded-pill px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="ms-2">Email học sinh/giáo viên</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="ms-2">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill px-4" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword" class="ms-2">Xác nhận mật khẩu</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>
                
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary rounded-pill fw-bold shadow-sm py-2 mt-2">
                    <i class="fas fa-user-plus me-2"></i>ĐĂNG KÝ
                </button>
            </form>

            <div class="mt-4 text-center">
                <p class="small text-muted">Đã có tài khoản? <a asp-page="./Login" class="text-decoration-none fw-bold text-primary">Đăng nhập tại đây</a></p>
            </div>
        </div>

        @* Giữ nguyên phần dịch vụ ngoài nhưng bọc trong một cột riêng cho đẹp *@
        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="col-md-5 col-md-offset-1 border-start ps-5">
                <section>
                    <h3 class="fw-bold text-dark h5 mb-3">Đăng ký bằng dịch vụ khác</h3>
                    <hr />
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div class="d-grid gap-2">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-dark" name="provider" value="@provider.Name" title="Đăng ký bằng @provider.DisplayName">
                                    <i class="fab fa-@provider.Name.ToLower() me-2"></i> @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </section>
            </div>
        }
    </div>
</div>

<style>
    /* Chỉnh vị trí label cho khớp với bo tròn của rounded-pill */
    .form-floating > label {
        padding-left: 1.5rem;
    }
    /* Chỉnh khung form */
    .rounded-4 {
        border-radius: 1rem !important;
    }
    /* Hiệu ứng nút bấm */
    #registerSubmit:hover {
        background-color: #0056b3;
        transition: 0.3s;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}